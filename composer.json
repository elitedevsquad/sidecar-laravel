{
    "name": "elitedevsquad/sidecar-extension-bridge",
    "type": "library",
    "license": "proprietary",
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0 | ^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.24",
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-laravel": "^3.2",
        "orchestra/testbench": "^10.4",
        "laradumps/laradumps": "^4.3"
    },
    "scripts": {
        "fix": "./vendor/bin/pint",
        "pint": "./vendor/bin/pint --test",
        "test": "./vendor/bin/pest",
        "test:coverage": "./vendor/bin/pest --coverage"
    },
    "autoload": {
        "psr-4": {
            "EliteDevSquad\\SidecarExtensionBridge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "EliteDevSquad\\SidecarExtensionBridge\\Providers\\SidecarServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
