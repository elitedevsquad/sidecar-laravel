{
    "name": "elitedevsquad/sidecar-laravel",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0|^11.0"
    },
    "require-dev": {
        "laravel/pint": "^1.24",
        "pestphp/pest": "^4.0|^3.8",
        "pestphp/pest-plugin-laravel": "^4.0|^3.2",
        "orchestra/testbench": "^10.4|^9.4",
        "laradumps/laradumps": "^4.3",
        "larastan/larastan": "^3.0"
    },
    "scripts": {
        "fix": "pint",
        "test:lint": "pint --test",
        "test:types": "phpstan analyse --ansi src/",
        "test:unit": "pest --colors=always --coverage --min=95 --compact",
        "test:debug": "laradumps check --dir=src,tests --text=dump,dd",
        "test": [
            "@test:debug",
            "@test:lint",
            "@test:types",
            "@test:unit"
        ]
    },
    "autoload": {
        "psr-4": {
            "EliteDevSquad\\SidecarLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "EliteDevSquad\\SidecarLaravel\\Providers\\SidecarServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
